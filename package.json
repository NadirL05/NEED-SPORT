{
  "name": "need-sport",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "node --import tsx --test --experimental-test-coverage --test-coverage-include='lib/product-search.ts' --test-coverage-include='components/ShopSection.tsx' --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 tests/**/*.test.ts tests/**/*.test.tsx",
    "test:e2e": "playwright test",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "admin:2fa": "tsx scripts/admin-2fa-setup.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@stripe/react-stripe-js": "^6.5.0",
    "@stripe/stripe-js": "^9.7.0",
    "@vercel/blob": "^2.4.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.13.0",
    "stripe": "^22.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "happy-dom": "^20.10.6",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
